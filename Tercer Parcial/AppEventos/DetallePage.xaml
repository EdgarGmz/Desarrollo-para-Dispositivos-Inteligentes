<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEventos.DetallePage"
             Title="Detalles del Partido"
             BackgroundColor="#F8F9FA">
    <ScrollView>
        <StackLayout
            Padding="0"
            Spacing="0">
            
            <!-- Imagen de Encabezado -->
            <Image
                Source="{Binding Miniatura}"
                Aspect="AspectFill"
                HeightRequest="280"/>
            
            <!-- Contenido Principal -->
            <StackLayout
                Padding="24,24,24,20"
                Spacing="16"
                BackgroundColor="White">
                
                <!-- Título -->
                <Label 
                    Text="{Binding Titulo}"
                    FontSize="26"
                    FontAttributes="Bold"
                    TextColor="#1A1A1A"
                    LineBreakMode="WordWrap"/>
                
                <!-- Separador visual -->
                <BoxView
                    HeightRequest="1"
                    Color="#E0E0E0"
                    Margin="0,8,0,8"/>
                
                <!-- Contenedor de información -->
                <StackLayout Spacing="12">
                    
                    <!-- Fecha con ícono -->
                    <StackLayout
                        Orientation="Horizontal"
                        Spacing="12"
                        Padding="12">
                        <Label
                            Text="📅"
                            FontSize="20"/>
                        <StackLayout
                            Spacing="2"
                            VerticalOptions="Center">
                            <Label
                                Text="Fecha"
                                FontSize="12"
                                TextColor="#999999"
                                FontAttributes="Bold"/>
                            <Label
                                Text="{Binding Fecha}"
                                FontSize="16"
                                TextColor="#333333"
                                FontAttributes="Bold"/>
                        </StackLayout>
                    </StackLayout>
                    
                    <!-- Liga con ícono -->
                    <StackLayout
                        Orientation="Horizontal"
                        Spacing="12"
                        Padding="12">
                        <Label
                            Text="🏆"
                            FontSize="20"/>
                        <StackLayout
                            Spacing="2"
                            VerticalOptions="Center">
                            <Label
                                Text="Competencia"
                                FontSize="12"
                                TextColor="#999999"
                                FontAttributes="Bold"/>
                            <Label
                                Text="{Binding Liga}"
                                FontSize="16"
                                TextColor="#333333"
                                FontAttributes="Bold"/>
                        </StackLayout>
                    </StackLayout>
                    
                </StackLayout>
                
                <!-- Botón Ver Video -->
                <Button
                    Text="▶ Ver Video"
                    x:Name="btnVerVideo"
                    Clicked="btnVerVideo_Clicked"
                    BackgroundColor="#FF6B6B"
                    TextColor="White"
                    CornerRadius="10"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="20,15"
                    Margin="0,16,0,0"/>
                
                <Button
                    Text="Volver"
                    Clicked="OnBackClicked"
                    BackgroundColor="#F0F0F0"
                    TextColor="#333333"
                    CornerRadius="10"
                    FontSize="14"
                    Padding="20,12"
                    Margin="0,8,0,0"/>
                
            </StackLayout>
            
        </StackLayout>
    </ScrollView>
</ContentPage>